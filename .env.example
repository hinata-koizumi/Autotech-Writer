# --- Database Configuration ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/autotech?sslmode=disable

# --- Go Collector Configuration ---
WEBHOOK_URL=http://localhost:8000/trigger
FETCH_INTERVAL_MINUTES=15
# ARXIV_CATEGORIES=cs.LG,cs.AI
# GITHUB_REPOS=openai/openai-python,langchain-ai/langchain

# --- Python LLM & X API Configuration ---
# OpenAI API Key (Required for GPT-x models)
OPENAI_API_KEY=sk-...
# Anthropic API Key (Required for Claude-x models)
ANTHROPIC_API_KEY=sk-ant-...

# X (Twitter) API v2 Bearer Token
# Long-form Articles usually require User Context OAuth 2.0 or 1.0a
X_ACCESS_TOKEN=...

# --- Safety & Debugging ---
# Set to 'true' to skip actual X posting and use minimal LLM costs
DR_RUN=true
# (Optional) Webhook to see generated content in dry-run
# DRY_RUN_WEBHOOK_URL=http://...

# Article Constraints
# MIN_ARTICLE_LENGTH=1500
# MAX_ARTICLE_LENGTH=2500
