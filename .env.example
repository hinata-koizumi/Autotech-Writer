# --- Database Configuration ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/autotech?sslmode=disable

# --- Go Collector Configuration ---
WEBHOOK_URL=http://localhost:8000/trigger
FETCH_INTERVAL_MINUTES=15
# GitHub Token (Optional but recommended for PR enrichment)
# GH_TOKEN=ghp_...
# ARXIV_CATEGORIES=cs.LG,cs.AI,cs.CV,cs.SE
# GITHUB_REPOS=openai/openai-python,langchain-ai/langchain

# --- Python LLM & X API Configuration ---
# OpenAI API Key (Required for GPT-x models)
OPENAI_API_KEY=sk-...
# Anthropic API Key (Required for Claude-x models)
ANTHROPIC_API_KEY=sk-ant-...

# --- X (Twitter) API Configuration ---
X_API_KEY=...
X_API_SECRET=...
X_ACCESS_TOKEN=...
X_ACCESS_SECRET=...

# --- Safety & Debugging ---
# Set to 'true' to skip actual X posting and use mock LLM responses where possible
DRY_RUN=true
# (Optional) Webhook to see generated content in dry-run
# DRY_RUN_WEBHOOK_URL=http://...

# Article Constraints (Default: 1000-3000)
# MIN_ARTICLE_LENGTH=1000
# MAX_ARTICLE_LENGTH=3000
